# monty-server configuration — copy to `.env` and adjust.
# Every variable is optional; the server runs with safe defaults if unset.

# --- Networking -----------------------------------------------------------
# Listen port. Railway and most PaaS providers inject this automatically.
PORT=8080
# Listen address. Defaults to 0.0.0.0 (all interfaces).
# MONTY_HOST=0.0.0.0

# --- Authentication & rate limiting --------------------------------------
# Comma-separated API tokens. Each entry is one of:
#   token                       -> token is also its display name, default rate
#   name:token                  -> named token, default rate
#   name:token:requests_per_min -> named token with a custom rate limit
# If unset, authentication is DISABLED and requests are rate limited per IP.
# MONTY_API_TOKENS=alice:sk-alice-secret:240,bob:sk-bob-secret

# Default rate limit (requests/minute) for tokens without an explicit rate,
# and for per-IP limiting when auth is disabled.
# MONTY_RATE_LIMIT_RPM=120

# --- Concurrency & request size ------------------------------------------
# Maximum monty executions running at once. Defaults to the CPU count.
# MONTY_MAX_CONCURRENCY=8
# Maximum accepted request body size, in bytes (default 1 MiB).
# MONTY_MAX_BODY_BYTES=1048576

# --- Execution limits -----------------------------------------------------
# Clients may request lower limits, never higher; requests are clamped to max.
# MONTY_DEFAULT_TIMEOUT_MS=5000
# MONTY_MAX_TIMEOUT_MS=30000
# MONTY_DEFAULT_MEMORY_BYTES=67108864
# MONTY_MAX_MEMORY_BYTES=268435456
# MONTY_DEFAULT_MAX_ALLOCATIONS=5000000
# MONTY_MAX_ALLOCATIONS=50000000
# MONTY_DEFAULT_RECURSION_DEPTH=1000
# MONTY_MAX_RECURSION_DEPTH=4000

# --- Sessions -------------------------------------------------------------
# MONTY_SESSION_TTL_SECONDS=300
# MONTY_SESSION_MAX_TTL_SECONDS=3600
# MONTY_MAX_SESSIONS=1000

# --- CORS -----------------------------------------------------------------
# Comma-separated allowed origins. Unset disables CORS; `*` allows any origin.
# MONTY_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- Logging --------------------------------------------------------------
# Verbosity (tracing EnvFilter syntax). Default: info.
# RUST_LOG=info,monty_server=debug
# Set to `json` for machine-readable logs.
# MONTY_LOG_FORMAT=json
